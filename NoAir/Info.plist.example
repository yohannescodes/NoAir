<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	Copy this file to NoAir/Info.plist and replace YOUR_GEMINI_KEY_HERE with
	your Google AI Studio key (https://aistudio.google.com/apikey).

	Info.plist itself is gitignored so the key never lands in history. Xcode's
	GENERATE_INFOPLIST_FILE = YES will still merge the standard usage-string
	keys in at build time; only this GeminiAPIKey entry needs to be here.
	-->
	<key>GeminiAPIKey</key>
	<string>YOUR_GEMINI_KEY_HERE</string>
</dict>
</plist>
